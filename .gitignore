# Synced external agent definitions (manifests and sync script are committed)
.claude/agents/external/*/
!.claude/agents/external/.gitkeep

# Audio and video recordings (large files)
recordings/*
!recordings/.gitkeep

# Third-party source clones are local-only. Commit oss/projects.yaml instead.
oss/clones/*
!oss/clones/.gitkeep

# Interview artifacts (can be large or contain sensitive content)
interviews/*
!interviews/.gitkeep

# Process-package recordings and interviews (keep .gitkeep)
*/recordings/*
!*/recordings/.gitkeep
*/interviews/*
!*/interviews/.gitkeep

# OpenSpec changes are committed for review and CI validation.

# Context state files
.context/

# Visual companion session artifacts
.superpowers/

# Obsidian personal workspace settings
docs/knowledge/.obsidian/workspace.json
docs/knowledge/.obsidian/graph.json

# macOS
.DS_Store

# Session trace files (instance-level, not committed)
*/.trace/

# Python virtual environments
.venv/
venv/

# Common build artifacts
node_modules/
__pycache__/
*.pyc
*.log
.omc/

# Generated harness adapter artifacts (regenerate via:
#   python3 scripts/lincoln-setup.py generate-harness --harness codex --harness opencode)
.opencode/
AGENTS.md
