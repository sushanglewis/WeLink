{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lincoln-framework.dev/schemas/stage-definition.schema.json",
  "title": "Lincoln Stage Definition Schema",
  "description": "Validates a single Lincoln stage YAML file under .claude/stages/.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "templates",
    "prerequisite_stage",
    "next_stage",
    "human_gate",
    "agent",
    "skills",
    "artifacts",
    "context",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the stage schema"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Kebab-case stage identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable stage name"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "What this stage does and when it is triggered"
    },
    "templates": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["all"],
          "description": "This stage applies to all workflow templates"
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "minItems": 1,
          "description": "List of workflow template IDs that include this stage"
        }
      ]
    },
    "prerequisite_stage": {
      "oneOf": [
        { "type": "string", "pattern": "^[a-z][a-z0-9-/]*$" },
        { "type": "null" }
      ],
      "description": "Stage that must complete before this one, or null for entry stages"
    },
    "next_stage": {
      "oneOf": [
        { "type": "string", "pattern": "^[a-z][a-z0-9-/]*$" },
        { "type": "null" }
      ],
      "description": "Stage that follows this one, or null for terminal stages"
    },
    "human_gate": {
      "type": "boolean",
      "description": "Whether human approval is required to exit this stage"
    },
    "agent": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Primary agent role for this stage"
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "default": [],
          "description": "Optional reviewer agent roles"
        },
        "handoff_to": {
          "oneOf": [
            { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            { "type": "null" }
          ],
          "description": "Agent role to hand off to at stage end"
        }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*(:[a-z][a-z0-9-]*)*$"
          },
          "default": [],
          "description": "Skills that must be available for this stage"
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*(:[a-z][a-z0-9-]*)*$"
          },
          "default": [],
          "description": "Skills that may be used but are not mandatory"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Path templates for artifacts that must be produced"
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Path templates for optional artifacts"
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": ["goal"],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1,
          "description": "What the agent should achieve in this stage"
        },
        "entry": {
          "type": "string",
          "description": "Checks and preparation before stage execution"
        },
        "execution": {
          "type": "string",
          "description": "How to perform the stage work"
        },
        "exit": {
          "type": "string",
          "description": "AI-evaluable criteria for completing the stage"
        },
        "constraints": {
          "type": "string",
          "description": "Additional constraints and guardrails"
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "properties": {
        "entry": {
          "type": "array",
          "items": { "$ref": "#/definitions/gateCheck" },
          "default": []
        },
        "exit": {
          "type": "array",
          "items": { "$ref": "#/definitions/gateCheck" },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "gateCheck": {
      "type": "object",
      "required": ["check"],
      "properties": {
        "check": {
          "type": "string",
          "enum": [
            "file_exists",
            "artifact_exists",
            "artifacts_present",
            "audio_format_supported",
            "previous_stage_completed",
            "human_approved",
            "gate_review_passed"
          ]
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      },
      "additionalProperties": false
    }
  }
}
