{
  "name": "lincoln",
  "version": "1.2.0",
  "description": "Cross-tool terminal UI for recording Lincoln interviews",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lincoln": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "lint": "echo 'lint not configured'"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "lincoln",
    "interview",
    "recording",
    "tui"
  ],
  "license": "MIT"
}
